# =========================================================
# CONFIGURACIÓN DE ENTORNO - Proyecto S.S. Sirio
# =========================================================
# INSTRUCCIONES:
# 1. Copia este archivo como ".env" (sin .example)
# 2. Rellena los valores reales de tu entorno local
# 3. NUNCA subas el archivo .env al repositorio Git
# =========================================================

# --- BASE DE DATOS POSTGRESQL ---
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql://postgres:TU_CONTRASEÑA_AQUI@localhost:5432/bibliografia_sirio

# --- CONFIGURACIÓN DE FLASK ---
# Clave secreta para sesiones (genera una aleatoria en producción)
SECRET_KEY=cambia_esto_por_algo_aleatorio_y_seguro

# --- MODO DE EJECUCIÓN ---
# Valores: development, production
FLASK_ENV=development

# --- DEBUG MODE ---
# Valores: True, False
DEBUG=True

# --- CARPETA DE UPLOADS ---
# Ruta relativa donde se guardan las imágenes subidas
UPLOAD_FOLDER=static/uploads

# --- API DE ANTHROPIC (CLAUDE) ---
# Obtén tu API key en: https://console.anthropic.com/
# Necesaria para funciones de IA: corrección de OCR, resúmenes, chatbot
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxx
